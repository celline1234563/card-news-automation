{
  "version": "1.0",
  "description": "카드 타입별 레이아웃 패턴 카탈로그 — Gemini 디자이너에게 전달",

  "grids": {
    "single-center": {
      "description": "중앙 정렬, 단일 메시지 강조",
      "areas": { "content": { "x": 60, "y": 200, "w": 960, "h": 950 } }
    },
    "top-image-bottom-text": {
      "description": "상단 2/3 이미지 + 하단 1/3 텍스트",
      "areas": {
        "image": { "x": 0, "y": 0, "w": 1080, "h": 900 },
        "text": { "x": 60, "y": 920, "w": 960, "h": 370 }
      }
    },
    "left-bar-right-text": {
      "description": "좌측 컬러 바 8px + 우측 텍스트",
      "areas": {
        "bar": { "x": 60, "y": 200, "w": 8, "h": 950 },
        "text": { "x": 100, "y": 200, "w": 920, "h": 950 }
      }
    },
    "stat-highlight": {
      "description": "중앙 대형 숫자 + 하단 레이블",
      "areas": {
        "stat": { "x": 60, "y": 350, "w": 960, "h": 400 },
        "label": { "x": 60, "y": 780, "w": 960, "h": 400 }
      }
    },
    "split-compare": {
      "description": "좌우 2분할 비교",
      "areas": {
        "left": { "x": 60, "y": 200, "w": 450, "h": 950 },
        "right": { "x": 570, "y": 200, "w": 450, "h": 950 }
      }
    },
    "card-list": {
      "description": "아이콘+텍스트 리스트 (3~5 항목)",
      "areas": {
        "header": { "x": 60, "y": 100, "w": 960, "h": 200 },
        "list": { "x": 60, "y": 320, "w": 960, "h": 900 }
      }
    }
  },

  "patterns": {
    "hook": [
      {
        "name": "bold-overlay",
        "description": "풀블리드 배경 + 다크 오버레이 + 대형 헤드라인",
        "grid": "top-image-bottom-text",
        "headline_size": "h1",
        "bg_treatment": "image_or_gradient_with_overlay",
        "rules": { "max_text_lines": 3, "require_emphasis": true, "bg_required": false }
      },
      {
        "name": "center-impact",
        "description": "중앙 대형 텍스트 + 미니멀 배경",
        "grid": "single-center",
        "headline_size": "display",
        "bg_treatment": "solid_primary",
        "rules": { "max_text_lines": 2, "require_emphasis": true, "bg_required": false }
      },
      {
        "name": "split-hook",
        "description": "좌측 컬러 블록 + 우측 텍스트",
        "grid": "left-bar-right-text",
        "headline_size": "h1",
        "bg_treatment": "gradient_subtle",
        "rules": { "max_text_lines": 3, "require_emphasis": true, "bg_required": false }
      }
    ],

    "problem": [
      {
        "name": "sidebar-quote",
        "description": "좌측 프라이머리 바 + 인용문 스타일",
        "grid": "left-bar-right-text",
        "headline_size": "h2",
        "bg_treatment": "solid_background",
        "rules": { "max_text_lines": 5, "require_emphasis": false, "bg_required": false }
      },
      {
        "name": "speech-bubble",
        "description": "말풍선 형태 인용문 + 발화자 표시",
        "grid": "single-center",
        "headline_size": "h2",
        "bg_treatment": "solid_background",
        "rules": { "max_text_lines": 4, "require_emphasis": false, "bg_required": false }
      },
      {
        "name": "icon-grid-problem",
        "description": "2x2 아이콘 그리드로 문제 나열",
        "grid": "card-list",
        "headline_size": "h2",
        "bg_treatment": "solid_background",
        "rules": { "max_text_lines": 2, "require_emphasis": false, "bg_required": false }
      }
    ],

    "data": [
      {
        "name": "big-number",
        "description": "초대형 숫자 중앙 + 하단 설명",
        "grid": "stat-highlight",
        "headline_size": "display",
        "bg_treatment": "solid_background",
        "rules": { "max_text_lines": 3, "require_emphasis": false, "bg_required": false }
      },
      {
        "name": "number-with-bar",
        "description": "좌측 컬러 바 + 우측 숫자·설명",
        "grid": "left-bar-right-text",
        "headline_size": "h1",
        "bg_treatment": "solid_background",
        "rules": { "max_text_lines": 4, "require_emphasis": false, "bg_required": false }
      },
      {
        "name": "number-with-icon",
        "description": "상단 아이콘 + 중앙 숫자 + 하단 텍스트",
        "grid": "single-center",
        "headline_size": "display",
        "bg_treatment": "gradient_subtle",
        "rules": { "max_text_lines": 3, "require_emphasis": false, "bg_required": false }
      }
    ],

    "insight": [
      {
        "name": "step-flow",
        "description": "번호 매긴 4단계 세로 플로우",
        "grid": "card-list",
        "headline_size": "h2",
        "bg_treatment": "solid_background",
        "rules": { "max_text_lines": 2, "require_emphasis": false, "bg_required": false }
      },
      {
        "name": "icon-card",
        "description": "상단 아이콘 + 중앙 텍스트 카드",
        "grid": "single-center",
        "headline_size": "h2",
        "bg_treatment": "solid_background",
        "rules": { "max_text_lines": 5, "require_emphasis": true, "bg_required": false }
      },
      {
        "name": "left-accent-insight",
        "description": "좌측 강조 바 + 인사이트 텍스트",
        "grid": "left-bar-right-text",
        "headline_size": "h2",
        "bg_treatment": "solid_background",
        "rules": { "max_text_lines": 5, "require_emphasis": true, "bg_required": false }
      }
    ],

    "solution": [
      {
        "name": "checklist",
        "description": "체크 아이콘 + 항목 리스트",
        "grid": "card-list",
        "headline_size": "h2",
        "bg_treatment": "solid_background",
        "rules": { "max_text_lines": 2, "require_emphasis": false, "bg_required": false }
      },
      {
        "name": "numbered-steps",
        "description": "번호 매긴 스텝형",
        "grid": "card-list",
        "headline_size": "h2",
        "bg_treatment": "solid_background",
        "rules": { "max_text_lines": 2, "require_emphasis": false, "bg_required": false }
      },
      {
        "name": "compare-columns",
        "description": "Before/After 좌우 비교",
        "grid": "split-compare",
        "headline_size": "h3",
        "bg_treatment": "solid_background",
        "rules": { "max_text_lines": 4, "require_emphasis": false, "bg_required": false }
      }
    ],

    "example": [
      {
        "name": "case-card",
        "description": "사례 카드 — 이름·점수·기간 강조",
        "grid": "single-center",
        "headline_size": "h2",
        "bg_treatment": "solid_background",
        "rules": { "max_text_lines": 5, "require_emphasis": true, "bg_required": false }
      },
      {
        "name": "info-grid",
        "description": "2x2 정보 그리드",
        "grid": "card-list",
        "headline_size": "h2",
        "bg_treatment": "solid_background",
        "rules": { "max_text_lines": 2, "require_emphasis": false, "bg_required": false }
      },
      {
        "name": "quote-testimonial",
        "description": "인용문 + 발화자 형태 후기",
        "grid": "left-bar-right-text",
        "headline_size": "h2",
        "bg_treatment": "solid_background",
        "rules": { "max_text_lines": 4, "require_emphasis": false, "bg_required": false }
      }
    ],

    "summary": [
      {
        "name": "bullet-recap",
        "description": "핵심 3~5개 불릿 리스트",
        "grid": "card-list",
        "headline_size": "h2",
        "bg_treatment": "solid_background",
        "rules": { "max_text_lines": 2, "require_emphasis": false, "bg_required": false }
      },
      {
        "name": "number-recap",
        "description": "숫자 매긴 핵심 정리",
        "grid": "card-list",
        "headline_size": "h2",
        "bg_treatment": "gradient_subtle",
        "rules": { "max_text_lines": 2, "require_emphasis": false, "bg_required": false }
      },
      {
        "name": "center-summary",
        "description": "중앙 정렬 핵심 메시지",
        "grid": "single-center",
        "headline_size": "h1",
        "bg_treatment": "solid_background",
        "rules": { "max_text_lines": 4, "require_emphasis": true, "bg_required": false }
      }
    ],

    "cta": [
      {
        "name": "full-primary-cta",
        "description": "프라이머리 풀배경 + 흰색 텍스트 + CTA 버튼",
        "grid": "single-center",
        "headline_size": "h1",
        "bg_treatment": "solid_primary",
        "rules": { "max_text_lines": 3, "require_emphasis": true, "bg_required": false }
      },
      {
        "name": "gradient-cta",
        "description": "그라디언트 배경 + CTA 버튼",
        "grid": "single-center",
        "headline_size": "h1",
        "bg_treatment": "gradient_primary",
        "rules": { "max_text_lines": 3, "require_emphasis": true, "bg_required": false }
      },
      {
        "name": "minimal-cta",
        "description": "화이트 배경 + 프라이머리 CTA 버튼",
        "grid": "single-center",
        "headline_size": "h2",
        "bg_treatment": "solid_background",
        "rules": { "max_text_lines": 4, "require_emphasis": true, "bg_required": false }
      }
    ]
  },

  "template_mapping": {
    "cover-bold": "hook.bold-overlay",
    "cover-basic": "problem.sidebar-quote",
    "cover-photo": "hook.bold-overlay",
    "basic-stat": "data.big-number",
    "basic-step-number": "insight.step-flow",
    "basic-list": "solution.checklist",
    "basic-info": "example.info-grid",
    "basic-compare": "solution.compare-columns",
    "basic-speech": "problem.speech-bubble",
    "basic-cta": "cta.full-primary-cta"
  }
}
