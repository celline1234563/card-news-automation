{
  "version": "2.0",
  "checks": {
    "text_line_count": {
      "severity": "fail",
      "description": "2~6번 카드 텍스트가 3줄 이내인가",
      "max_lines": 3,
      "skip_cards": [1],
      "auto_fix": false
    },
    "image_text_separation": {
      "severity": "fail",
      "description": "이미지와 텍스트 영역이 물리적으로 분리됐는가",
      "auto_fix": false
    },
    "color_limit": {
      "severity": "warn",
      "description": "브랜드 컬러가 2가지 이내인가",
      "max_colors": 2,
      "auto_fix": false,
      "allowed_hex": ["#FFFFFF", "#ffffff", "#fff", "#111111", "#000000", "#000"]
    },
    "visual_point": {
      "severity": "warn",
      "description": "비주얼 포인트가 카드당 1개인가",
      "max_points": 1,
      "auto_fix": false
    },
    "spacing": {
      "severity": "fail",
      "description": "사방 여백이 40px 이상이고 safe-area 60px인가",
      "min_margin": 40,
      "min_padding": 40,
      "safe_area": 60,
      "auto_fix": true
    },
    "text_overflow": {
      "severity": "fail",
      "description": "텍스트가 영역 밖으로 나가거나 잘리는가",
      "auto_fix": true
    },
    "brand_consistency": {
      "severity": "warn",
      "description": "브랜드 요소(로고, CTA 버튼, 숫자 등)가 올바르게 표시되는가",
      "auto_fix": false
    },
    "token_font_size": {
      "severity": "warn",
      "description": "토큰에 정의된 폰트 사이즈 스케일을 벗어나는가",
      "allowed_sizes": [14, 16, 20, 24, 28, 36, 48, 72, 96, 120],
      "tolerance": 4,
      "auto_fix": false
    }
  },
  "pass_threshold": 6,
  "fail_checks": ["text_overflow", "image_text_separation", "spacing"],
  "png_qa": {
    "readability_threshold": 6,
    "aesthetic_threshold": 6,
    "text_cutoff_fail": true,
    "image_broken_fail": true
  }
}
