# ============================================
# 카드뉴스 자동화 시스템 환경변수
# 이 파일을 .env로 복사한 뒤 실제 값을 입력하세요
# cp .env.example .env
# ============================================

# AI API Keys
ANTHROPIC_API_KEY=sk-ant-...        # Claude API 키 (Anthropic Console에서 발급)
GOOGLE_AI_API_KEY=AIza...           # Gemini API 키 (Google AI Studio에서 발급)

# Google Service Account
GOOGLE_SERVICE_ACCOUNT_PATH=./config/google-service-account.json  # 서비스 계정 JSON 파일 경로

# Notion
NOTION_API_KEY=ntn_...              # Notion Integration 토큰
NOTION_DATABASE_ID=                 # 콘텐츠 캘린더 DB UUID
NOTION_DATASOURCE_ID=               # Notion DataSource ID (DB retrieve에서 확인)

# 학원 설정
DEFAULT_ACADEMY=jinhak              # 기본 학원 키 (ollinone / jinhak / toktok)

# 파이프라인 설정
MAX_HOOK_RETRY=3                    # 후킹 재작성 최대 횟수
MAX_DESIGN_RETRY=2                  # 디자인 재시도 최대 횟수
HOOK_PASS_SCORE=7                   # 후킹 통과 점수 (7점 만점)
POLLER_INTERVAL=30000               # 노션 폴링 간격 (ms)

# remove.bg (누끼)
REMOVEBG_API_KEY=                   # remove.bg API 키 (https://www.remove.bg/api 에서 발급, 월 50장 무료)

# Google Chat (알림용)
GCHAT_WEBHOOK_URL=                  # Google Chat 웹훅 URL

# Figma (디자인 토큰용)
FIGMA_TOKEN=                        # Figma Personal Access Token
FIGMA_FILE_KEY=                     # Figma 파일 키
